---
import {storyblokEditable} from '@storyblok/astro'
import {below, getSrcset} from '@/utils'

const {blok, items, projectName, paragraph, image} = Astro.props;
---

<section
  {...storyblokEditable(blok)}
  class="border-white bg-gray-light lg:border-b"
>
    <div class="h-(--header-height)"></div>

    <div class="container-fluid grid grid-cols-1 px-container lg:grid-cols-[40%_60%] lg:divide-x lg:divide-white">
        <div class="pt-24 pb-12">
            <h1 class="text-3xl lg:text-4xl">
                {projectName}
            </h1>

            <div
              class="mt-16 grid grid-cols-[5rem_1fr] gap-8 text-sm whitespace-pre-line"
            >
                {items.map(item => (
                    <label class="uppercase-wide">
                        {item.label}
                    </label>

                    <div>
                        {item.text}
                    </div>
                ))}
            </div>
        </div>

        {(paragraph || image) && (
          <div class="border-white border-t pt-12 pb-4 lg:border-t-0 lg:pb-8 lg:pl-8">
              {paragraph && (
                <p class="mb-8">
                  {paragraph}
                </p>
              )}

              {image && (
                <picture>
                  <source
                    media={below.sm}
                    srcset={getSrcset(image, 607)}
                    width="607"
                  />

                  <source
                    media={below.lg}
                    srcset={getSrcset(image, 959)}
                    width="959"
                  />

                  <source
                    media={below.xl}
                    srcset={getSrcset(image, 735)}
                    width="735"
                  />

                  <img
                    alt={image.alt || projectName}
                    loading="lazy"
                    class="skeleton"
                    srcset={getSrcset(image, 1040)}
                    title={image.title || projectName}
                    width="1040"
                  />
                </picture>
              )}
          </div>
        )}
    </div>
</section>
