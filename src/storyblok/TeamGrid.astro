---
import {storyblokEditable} from '@storyblok/astro'
import {below, getSrcset} from '@/utils'

const {blok, title, paragraph, items} = Astro.props
---

<section
  {...storyblokEditable(blok)}
  class="bg-gray-light py-4 md:py-12 lg:py-20"
>
    <div class="container-fluid px-container">
        <div class="grid gap-y-4 lg:grid-cols-12">
            <h2 class="uppercase-wide lg:col-span-5">
                {title}
            </h2>

            <p
              class="text-lg lg:col-span-5 lg:col-start-7 lg:text-2xl"
              set:html={paragraph}
            />
        </div>

        <div class="mt-12 grid grid-cols-2 gap-x-4 gap-y-8 md:gap-x-12 lg:mt-40 lg:grid-cols-3 lg:gap-16">
            {items.map(item => (
                <div>
                    <picture>
                        <source
                          media={below.sm}
                          srcset={getSrcset(item.image, 296, 370)}
                          width="296"
                          height="370"
                        />
                        <source
                          media={below.lg}
                          srcset={getSrcset(item.image, 472, 590)}
                          width="472"
                          height="590"
                        />
                        <img
                          alt={item.image.alt || item.title}
                          loading="lazy"
                          class="w-full skeleton"
                          srcset={getSrcset(item.image, 622, 778)}
                          title={item.image.title || item.title}
                          width="622"
                          height="778"
                        />
                    </picture>

                    <h3 class="mt-3 text-lg">
                        {item.title}
                    </h3>

                    {item.subtitle && (
                        <p class="text-sm uppercase-wide">
                            {item.subtitle}
                        </p>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>
