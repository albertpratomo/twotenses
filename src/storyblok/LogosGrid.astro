---
import {storyblokEditable} from '@storyblok/astro'
import LogosGrid from '@/components/LogosGrid.vue'

const {blok, items, title} = Astro.props;
---

<section
  {...storyblokEditable(blok)}
  class="bg-gray py-12 md:py-24"
>
    <div class="container-fluid grid-cols-12 px-container lg:grid">
        <h2
          class="text-red col-span-5 text-4xl md:text-7xl lg:whitespace-pre-line"
          set:html={title}
        />

        <div class="col-span-7 col-start-6 row-start-2 mt-8 px-10 sm:px-0 md:mt-12 lg:mt-0">
            <LogosGrid
              client:visible
              items={items}
            />
        </div>
    </div>
</section>
