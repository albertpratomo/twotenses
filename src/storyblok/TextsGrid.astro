---
import {storyblokEditable} from '@storyblok/astro'
import TextsGrid from '@/components/TextsGrid.vue'

let {blok, items, parallax = false} = Astro.props

items = items.map(item => item.text.split('\n'))

const width = 'sm:w-10/12 lg:w-full xl:w-10/12'
const containerClass = 'container-fluid px-container w-full flex justify-center';
---

<section
  {...storyblokEditable(blok)}
  id="texts-grid"
  class="flex-col bg-gray-light transition-colors duration-300 sm:h-screen"
  class:list={{'sticky inset-x-0 bottom-0 -z-10': parallax}}
>
    <div
      class="grow"
      class:list={containerClass}
    >
        <div
          class="border-white h-48 border-x sm:h-full"
          class:list={width}
        />
    </div>

    <TextsGrid
      client:visible
      items={items}
      width={width}
      container-class={containerClass}
    />

    <div
      class="grow"
      class:list={containerClass}
    >
        <div
          class="border-white h-48 border-x sm:h-full"
          class:list={width}
        />
    </div>
</section>
