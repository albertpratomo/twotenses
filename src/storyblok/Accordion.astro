---
import {storyblokEditable} from '@storyblok/astro'
import Accordion from '@/components/Accordion.vue'

interface Props {
    blok: any
    items: any[]
    title: string
}

const {blok, items, title} = Astro.props;
---

<section
  {...storyblokEditable(blok)}
  class="bg-gray-light"
>
    <div class="container-fluid px-container">
        <h2 class="border-white text-red border-l pt-12 pb-4 text-4xl md:pt-24 md:text-7xl">
            {title}
        </h2>
    </div>

    <Accordion
      client:visible
      items={items}
    />

    <div class="container-fluid px-container">
        <div class="border-white border-l pt-12 md:pt-24" />
    </div>
</section>
